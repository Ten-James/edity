{
  "name": "edity",
  "version": "1.0.0",
  "main": "electron/dist/electron/src/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p electron/tsconfig.json && wait-on http://localhost:1420 && VITE_DEV_SERVER_URL=http://localhost:1420 electron .",
    "build": "tsc -p electron/tsconfig.json && tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "package": "npm run build && electron-builder",
    "rebuild": "electron-rebuild"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Edity",
  "build": {
    "appId": "com.edity.app",
    "productName": "Edity",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/dist/**/*",
      "electron/preload.js",
      "electron/claude-hook.sh",
      "shared/**/*",
      "icon.png"
    ],
    "mac": {
      "icon": "icon.png",
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Edity needs microphone access so terminal programs (like Claude Code voice) can use it."
      }
    },
    "dmg": {
      "title": "Edity",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.88",
    "@fontsource-variable/inter": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@tabler/icons-react": "^3.40.0",
    "@tailwindcss/vite": "^4.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "node-pty": "^1.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.5",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  }
}
